{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "rootDir": ".",
    "jsx": "react-jsx"
  },
  "include": [
    "jssg/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "Test-repo",
    "build_codemod",
    "temp_proj"
  ]
}
